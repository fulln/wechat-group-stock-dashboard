# Required only for scripts that export directly from wechat-cli.
WECHAT_GROUP_NAME="My Group"

# Optional: display exported sender "me" as this value.
CHAT_STOCK_SELF_NAME="me"

# Optional: default 1 fetches Google Finance, intraday lines, and speaker-page daily K.
# Set 0 to generate the dashboards without external market fetches.
WITH_MARKET_DATA=1

# Optional: market snapshot channel.
# auto keeps Google Finance as primary and falls back to Sina quote; google/sina force one source.
MARKET_DATA_CHANNEL=auto

# Optional Cloudflare Pages settings.
CF_PAGES_PROJECT_NAME="group-stock-dashboard"
CF_PAGES_BRANCH="main"
# CLOUDFLARE_API_TOKEN="..."
